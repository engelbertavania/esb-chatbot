# Copy to .env and fill in real values. .env must NOT be committed.

# --- Gemini API (free tier, no billing) --------------------------------------
# Get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIzaSy...

# --- Database ----------------------------------------------------------------
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# --- Telegram bot ------------------------------------------------------------
TELEGRAM_TOKEN=123456789:ABC-DEF...
TELEGRAM_WEBHOOK_SECRET=some-random-string-32+chars

# --- Idle-session reaper -----------------------------------------------------
# Shared secret for the scheduled POST /reap sweep. Cloud Scheduler sends this
# as the X-Reap-Secret header; /reap rejects callers that don't match. Use a
# random 32+ char string. Leave unset locally to disable /reap.
REAP_SECRET=another-random-string-32+chars

# --- Vertex AI / GCP ---------------------------------------------------------
# Fill these in to use Vertex AI Search for retrieval AND/OR Vertex AI for
# the LLM. Run `gcloud auth application-default login` once for local dev.
GOOGLE_CLOUD_PROJECT=
# LLM region (ChatVertexAI) — real region, NOT "global"
GOOGLE_CLOUD_LOCATION=us-central1
# Vertex AI Search datastore location — almost always "global"
VERTEX_SEARCH_LOCATION=global
VERTEX_DATASTORE_ID=

# Only set when using a service-account JSON key (Cloud Run, CI, etc).
# For local dev with ADC (`gcloud auth application-default login`), leave empty.
GOOGLE_APPLICATION_CREDENTIALS=

# Set to "true" to force the LLM onto Vertex AI even when GOOGLE_API_KEY is
# also set. Default (false) prefers the Gemini API free tier when both exist.
PREFER_VERTEX_AI=false

# --- Server port (read by uvicorn; Cloud Run also injects this) --------------
PORT=8000
